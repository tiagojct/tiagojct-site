<mxfile host="app.diagrams.net" agent="Claude (initial scaffold)" version="22.0.0">
  <diagram name="search-recipe" id="sr1">
    <mxGraphModel dx="900" dy="500" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="900" pageHeight="460" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="t" value="A reproducible PubMed search, in eight steps" style="text;html=1;align=center;fontSize=13;fontStyle=1;fontColor=#0D2F42;" vertex="1" parent="1">
          <mxGeometry x="200" y="8" width="500" height="24" as="geometry"/>
        </mxCell>
        <mxCell id="s1" value="1. Frame as PICO&#xa;P · I · C · O&#xa;Population, Intervention,&#xa;Comparator, Outcome" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EAE1D7;strokeColor=#0082B1;strokeWidth=1.5;fontFamily=Atkinson Hyperlegible Next;fontSize=10;fontColor=#0D2F42;" vertex="1" parent="1">
          <mxGeometry x="20" y="50" width="190" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="s2" value="2. MeSH lookup&#xa;MeSH Database&#xa;canonical term per concept,&#xa;note synonyms" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EAE1D7;strokeColor=#0082B1;strokeWidth=1.5;fontFamily=Atkinson Hyperlegible Next;fontSize=10;fontColor=#0D2F42;" vertex="1" parent="1">
          <mxGeometry x="245" y="50" width="190" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="s3" value="3. Build blocks&#xa;(&quot;asthma&quot;[MeSH] OR&#xa;&quot;asthma&quot;[tiab])&#xa;one block per PICO concept" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EAE1D7;strokeColor=#0082B1;strokeWidth=1.5;fontFamily=Atkinson Hyperlegible Next;fontSize=10;fontColor=#0D2F42;" vertex="1" parent="1">
          <mxGeometry x="470" y="50" width="190" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="s4" value="4. Combine with AND&#xa;P AND I AND C AND O&#xa;Advanced Builder shows history;&#xa;combine #1 AND #2" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EAE1D7;strokeColor=#0082B1;strokeWidth=1.5;fontFamily=Atkinson Hyperlegible Next;fontSize=10;fontColor=#0D2F42;" vertex="1" parent="1">
          <mxGeometry x="695" y="50" width="190" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="s5" value="5. Filters (sparingly)&#xa;date · language · type&#xa;RCT, SR, Practice Guideline.&#xa;Filters can silently drop hits." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EAE1D7;strokeColor=#6A4A00;strokeWidth=1.5;fontFamily=Atkinson Hyperlegible Next;fontSize=10;fontColor=#0D2F42;" vertex="1" parent="1">
          <mxGeometry x="695" y="170" width="190" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="s6" value="6. Save to MyNCBI&#xa;&quot;Create alert&quot;&#xa;version-controls the query;&#xa;re-run anytime" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EAE1D7;strokeColor=#6A4A00;strokeWidth=1.5;fontFamily=Atkinson Hyperlegible Next;fontSize=10;fontColor=#0D2F42;" vertex="1" parent="1">
          <mxGeometry x="470" y="170" width="190" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="s7" value="7. Weekly email alert&#xa;PubMed mails new hits&#xa;leverage move — passive&#xa;surveillance of the literature" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EAE1D7;strokeColor=#6A4A00;strokeWidth=1.5;fontFamily=Atkinson Hyperlegible Next;fontSize=10;fontColor=#0D2F42;" vertex="1" parent="1">
          <mxGeometry x="245" y="170" width="190" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="s8" value="8. Send to Zotero&#xa;.nbib / .ris / Connector&#xa;references live in one place&#xa;with PDFs and notes" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#177C55;strokeColor=none;fontFamily=Atkinson Hyperlegible Next;fontSize=10;fontColor=#FFFFFF;" vertex="1" parent="1">
          <mxGeometry x="20" y="170" width="190" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="heur" value="Heuristics&#xa;·  Start broad, then narrow. A query that returns zero hits is almost always wrong, not exhaustive.&#xa;·  Within a concept use OR; between concepts use AND. NOT only at the very end, and only if necessary.&#xa;·  Pair MeSH with text-word fallback ([tiab]) — MeSH indexing lags 6–12 months.&#xa;·  Paste the Search Details translation in your Methods; that is your reproducible search.&#xa;·  Re-running the saved query 6 months later finds the new evidence; the alert does it for you in the meantime.&#xa;·  Filters are not free: &quot;Free full text&quot; excludes paywalled landmark trials. Use sparingly and document.&#xa;·  When in doubt, run two versions: a precise (MeSH-only) and a sensitive (MeSH + tiab + synonyms). Compare counts." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAF6F1;strokeColor=#0082B1;fontFamily=Atkinson Hyperlegible Next;fontSize=10;fontColor=#0D2F42;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="20" y="290" width="865" height="150" as="geometry"/>
        </mxCell>
        <mxCell id="e12" style="endArrow=classic;html=1;strokeColor=#835A49;strokeWidth=1.5;" edge="1" parent="1" source="s1" target="s2"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e23" style="endArrow=classic;html=1;strokeColor=#835A49;strokeWidth=1.5;" edge="1" parent="1" source="s2" target="s3"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e34" style="endArrow=classic;html=1;strokeColor=#835A49;strokeWidth=1.5;" edge="1" parent="1" source="s3" target="s4"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e45" style="endArrow=classic;html=1;strokeColor=#835A49;strokeWidth=1.5;" edge="1" parent="1" source="s4" target="s5"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e56" style="endArrow=classic;html=1;strokeColor=#835A49;strokeWidth=1.5;" edge="1" parent="1" source="s5" target="s6"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e67" style="endArrow=classic;html=1;strokeColor=#835A49;strokeWidth=1.5;" edge="1" parent="1" source="s6" target="s7"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e78" style="endArrow=classic;html=1;strokeColor=#835A49;strokeWidth=1.5;" edge="1" parent="1" source="s7" target="s8"><mxGeometry relative="1" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
