  author = {Moons, Karel G.M. and Altman, Douglas G. and Reitsma, Johannes B. and Ioannidis, John P.A. and Macaskill, Petra and Steyerberg, Ewout W. and Vickers, Andrew J. and Ransohoff, David F. and Collins, Gary S.},
  year = 2015,
