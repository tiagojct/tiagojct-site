<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Pequod — iTerm2 colour scheme
  https://tiagojct.eu/projects/pequod/

  Background: Log 950 (#0B1720).  Foreground: Log 100 (#EAE1D7).
  ANSI 0-7 mapped to Log + accent dark variants for legibility on Log 950.
  Bright variants brightened by ≈ 12-18% L*.

  Licence: CC-BY-4.0 (palette).  Tiago Jacinto, 2026.
-->
<plist version="1.0">
<dict>
  <!-- ── Foreground / background / cursor ───────────────────────────── -->

  <key>Background Color</key>
  <dict>
    <key>Color Space</key><string>sRGB</string>
    <key>Red Component</key><real>0.0431</real>
    <key>Green Component</key><real>0.0902</real>
    <key>Blue Component</key><real>0.1255</real>
    <key>Alpha Component</key><real>1.0</real>
  </dict>

  <key>Foreground Color</key>
  <dict>
    <key>Color Space</key><string>sRGB</string>
    <key>Red Component</key><real>0.9176</real>
